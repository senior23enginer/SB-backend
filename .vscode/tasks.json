      "command": "SKIP_GIT_PULL=1 ./scripts/dev-sync-and-run.sh",
      "problemMatcher": []
    },
    {
      "label": "Infra: Start Oracle",
      "type": "shell",
      "command": "docker compose -f docker/oracle/docker-compose.yml up -d",
      "problemMatcher": []
    }
  ]
}
