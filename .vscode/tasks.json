{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Sync + Run",
      "type": "shell",
      "command": "./scripts/dev-sync-and-run.sh",
      "problemMatcher": []
    },
    {
      "label": "Backend: Run (skip pull)",
